# mavenмќґлЇём§Ђм—ђ mvn packageлЎњ *.jar нЊЊмќј мѓќм„±
FROM maven:3.8-jdk-11-slim AS builder
WORKDIR /app
COPY ./ ./
RUN mvn package

# openjdk мќґлЇём§Ђм—ђ builderм—ђм„њ мѓќм„±лђњ *.jarнЊЊмќјмќ„ ліµм‚¬
FROM eclipse-temurin:11-jre
WORKDIR /app
COPY --from=builder /app/target/*.jar app.jar
CMD ["java", "-jar", "app.jar"]