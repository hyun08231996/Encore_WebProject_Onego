# MongoDB Atlas
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER_HOST/onego?retryWrites=true&w=majority

# Google Cloud Storage
GCP_STORAGE_BUCKET=your-production-bucket

# Cognito
COGNITO_ISSUER_URI=https://cognito-idp.ap-northeast-2.amazonaws.com/YOUR_USER_POOL_ID
VUE_APP_AWS_REGION=ap-northeast-2
VUE_APP_COGNITO_IDENTITY_POOL_ID=ap-northeast-2:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VUE_APP_COGNITO_USER_POOL_ID=ap-northeast-2_xxxxxxxx
VUE_APP_COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite
