FROM node:16-alpine AS builder
WORKDIR /app
ARG VUE_APP_AWS_REGION
ARG VUE_APP_COGNITO_IDENTITY_POOL_ID
ARG VUE_APP_COGNITO_USER_POOL_ID
ARG VUE_APP_COGNITO_APP_CLIENT_ID
ENV VUE_APP_AWS_REGION=$VUE_APP_AWS_REGION
ENV VUE_APP_COGNITO_IDENTITY_POOL_ID=$VUE_APP_COGNITO_IDENTITY_POOL_ID
ENV VUE_APP_COGNITO_USER_POOL_ID=$VUE_APP_COGNITO_USER_POOL_ID
ENV VUE_APP_COGNITO_APP_CLIENT_ID=$VUE_APP_COGNITO_APP_CLIENT_ID
COPY package.json ./
RUN yarn install --ignore-engines
COPY ./ ./
RUN yarn run build

FROM nginx
EXPOSE 3000
COPY ./nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html
